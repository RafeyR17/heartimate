{
  "name": "heartimate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security",
    "test:integration": "INTEGRATION_TEST=1 vitest run --config vitest.integration.config.ts",
    "test:llm-eval": "vitest run tests/llm-eval",
    "test:llm-eval:live": "vitest run --config vitest.llm-live.config.ts",
    "hooks:install": "husky",
    "prepare": "husky || true",
    "auth:wire": "node scripts/wire-clerk-supabase.mjs",
    "auth:verify": "node scripts/check-auth-setup.mjs",
    "auth:prove-idor": "INTEGRATION_TEST=1 vitest run --config vitest.integration.config.ts tests/integration/idor-api.test.ts tests/integration/rls-idor.test.ts",
    "audit:deps": "npm audit --audit-level=high",
    "audit:service-role": "grep -rE \"createSupabaseAdminClient|getServiceRoleClient\" lib app tests --include='*.ts' | grep -v '.test.ts' || true",
    "analyze": "next experimental-analyze",
    "analyze:webpack": "ANALYZE=true next build --webpack",
    "check:perf": "node scripts/check-perf.mjs",
    "check:bundle": "node scripts/check-bundle-budgets.mjs",
    "check:touch-targets": "node scripts/check-touch-targets.mjs",
    "check:lighthouse": "node scripts/check-lighthouse.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.3.5",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.11",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "path-browserify": "^1.0.1",
    "posthog-js": "^1.374.2",
    "posthog-node": "^5.34.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix --no-warn-ignored",
      "node scripts/lint-staged-tests.mjs"
    ]
  }
}
